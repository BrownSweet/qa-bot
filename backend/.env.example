# ===== 主数据库（存放系统自身数据）=====
# 默认使用 SQLite，零配置即可启动；切换 MySQL 时改为下面的示例
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/qabot

# ===== 安全 =====
# JWT 签名密钥（生产环境务必修改）
SECRET_KEY=6gd4kur9v8W7QoGufE1tahS_PpM5t9AOYeQ3l-xa_XQpNSjcFKcCLDykbnaw1aNz
# AES 加密密钥（用于数据库密码 / API Key 加密存储），任意字符串，内部会派生成 32 字节
AES_KEY=xStXKn8PTR66xrjkf8NmZu1vghmH9IgMwrcgSiluMyU

# JWT 过期时间（小时）
TOKEN_EXPIRE_HOURS=24
# 勾选“记住我”时的过期时间（小时）
TOKEN_REMEMBER_HOURS=720

# ===== DeepSeek（可在系统配置接口中覆盖）=====
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
